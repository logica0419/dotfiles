# ~/.profile: executed by the command interpreter for login shells.
{% if lookup("env", "ENV") == "wsl" %}
export BROWSER="/usr/bin/chrome"
{% endif %}

# Homebrew environment variables (PATH, MANPATH, INFOPATH, etc.)
eval "$({{ check_os_brew_base_path }}/bin/brew shellenv)"

# Rust and Cargo
if [ -f "{{ ansible_facts['user_dir'] }}/.cargo/env" ]; then
. "{{ ansible_facts['user_dir'] }}/.cargo/env"
fi

# Language and toolchain paths
export PATH="$PATH:/usr/local/go/bin"
export PATH="$PATH:{{ ansible_facts['user_dir'] }}/go/bin"
export PATH="$PATH:{{ ansible_facts['user_dir'] }}/.bun/bin"
export PATH="$PATH:{{ ansible_facts['user_dir'] }}/.krew/bin"
export PATH="$PATH:{{ ansible_facts['user_dir'] }}/.local/bin"
export PATH="$PATH:{{ ansible_facts['user_dir'] }}/.local/share/mise/shims"

if [ -f ~/.bashrc ]; then
. ~/.bashrc
fi
