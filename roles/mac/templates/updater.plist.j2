<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.dotfiles-updater</string>

    <key>ProgramArguments</key>
    <array>
      <string>{{ check_os_brew_base_path }}/bin/bash</string>
      <string>-lc</string>
      <string>
      set -a
      . "{{ ansible_facts.user_dir }}/.config/environment.d/env.conf"
      set +a
      exec uv run ansible-playbook -v -i inventory update-mac.yaml
      </string>
    </array>

    <key>WorkingDirectory</key>
    <string>{{ mac_dotfiles_dir.stdout }}</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>4</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>{{ ansible_facts.user_dir }}/.local/state/dotfiles/update-mac.log</string>
    <key>StandardErrorPath</key>
    <string>{{ ansible_facts.user_dir }}/.local/state/dotfiles/update-mac.log</string>
  </dict>
</plist>
