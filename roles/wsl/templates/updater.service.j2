[Unit]
Description=WSL updater

[Service]
Type=simple
User={{ ansible_user }}
Group={{ ansible_user }}
EnvironmentFile=-{{ ansible_facts.user_dir }}/.config/environment.d/env.conf
WorkingDirectory={{ wsl_dotfiles_dir.stdout }}
ExecStart={{ check_os_brew_base_path }}/bin/uv run ansible-playbook -v -i inventory update-linux.yaml

[Install]
WantedBy=multi-user.target
