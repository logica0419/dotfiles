[Unit]
Description=WSL updater

[Service]
Type=simple
User={{ ansible_user }}
Group={{ ansible_user }}
EnvironmentFile=-{{ ansible_facts.user_dir }}/.config/environment.d/env.conf
ExecStart={{ wsl_ansible_path.stdout }} -v -u {{ ansible_user }} -i {{ wsl_dotfiles_dir.stdout }}/inventory {{ wsl_dotfiles_dir.stdout }}/update-linux.yaml

[Install]
WantedBy=multi-user.target
